# Backend Environment Variables (for local development only)
# In Azure, these are set via App Service Configuration + Managed Identity

# SQL Server
DATABASE_HOST=localhost
DATABASE_NAME=allowance-db
DATABASE_PORT=1433

# Key Vault (not used locally — JWT_SECRET used instead)
# KEY_VAULT_URL=https://kv-allowanceapp-dev.vault.azure.net

# Local-only JWT secret (in Azure, this comes from Key Vault)
JWT_SECRET=local-dev-secret-change-me-in-production

# Server
PORT=3000
NODE_ENV=development
