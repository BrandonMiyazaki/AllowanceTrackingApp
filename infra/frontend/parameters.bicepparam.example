using './main.bicep'

param location = 'westus2'
param environmentName = 'dev'

// ---------------------------------------------------------------------------
// .NET version for Blazor Server
// ---------------------------------------------------------------------------
param dotnetVersion = '8.0'

// ---------------------------------------------------------------------------
// Step 1 Outputs — replace with actual resource ID from your deployment
// ---------------------------------------------------------------------------
param frontendSubnetId = '/subscriptions/<YOUR_SUBSCRIPTION_ID>/resourceGroups/rg-allowanceapp-dev/providers/Microsoft.Network/virtualNetworks/vnet-allowanceapp-dev/subnets/snet-appservice-frontend'

// ---------------------------------------------------------------------------
// Step 3 Outputs — replace with actual values from your deployment
// ---------------------------------------------------------------------------
param appServicePlanId = '/subscriptions/<YOUR_SUBSCRIPTION_ID>/resourceGroups/rg-allowanceapp-dev/providers/Microsoft.Web/serverfarms/asp-backend-allowanceapp-dev'
param backendApiHostname = '<YOUR_BACKEND_APP>.azurewebsites.net'
