using './main.bicep'

param location = 'westus2'
param environmentName = 'dev'

// ---------------------------------------------------------------------------
// Database SKU — Basic tier for dev; scale to S0/S1+ for production
// ---------------------------------------------------------------------------
param databaseSkuName = 'Basic'
param databaseSkuTier = 'Basic'

// ---------------------------------------------------------------------------
// Entra AD Admin — SQL Server administrator
// Replace with your own values
// ---------------------------------------------------------------------------
param entraAdminObjectId = '<YOUR_ENTRA_ADMIN_OBJECT_ID>'
param entraAdminLogin = '<YOUR_ENTRA_ADMIN_LOGIN>'
param tenantId = '<YOUR_TENANT_ID>'

// ---------------------------------------------------------------------------
// Step 1 Outputs — replace with actual resource IDs from your deployment
// ---------------------------------------------------------------------------
param peSqlSubnetId = '/subscriptions/<YOUR_SUBSCRIPTION_ID>/resourceGroups/rg-allowanceapp-dev/providers/Microsoft.Network/virtualNetworks/vnet-allowanceapp-dev/subnets/snet-pe-sql'
param sqlDnsZoneId = '/subscriptions/<YOUR_SUBSCRIPTION_ID>/resourceGroups/rg-allowanceapp-dev/providers/Microsoft.Network/privateDnsZones/privatelink.database.windows.net'

// ---------------------------------------------------------------------------
// Optional — Log Analytics workspace ID for SQL audit logging
// ---------------------------------------------------------------------------
param logAnalyticsWorkspaceId = ''
